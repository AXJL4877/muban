# Neon PostgreSQL（应用连接，推荐使用带 -pooler 的连接串）
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# 数据库迁移用直连（Neon 控制台「Direct connection」，无 -pooler）
# 本地开发若未使用连接池，可与 DATABASE_URL 相同
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 服务端数据加密（Vercel 必填；本地可与 data/.data-encryption.key 二选一）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_DATA_ENCRYPTION_KEY=""

# 微信公众号（可选，也可在页面「公众号配置」中填写）
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
