# Neon PostgreSQL（Vercel 部署请用 Neon 控制台「Direct connection」连接串，复制整段即可）
# 主机名不含 -pooler，例如：ep-xxx.region.aws.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 服务端数据加密（Vercel 必填；本地可与 data/.data-encryption.key 二选一）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_DATA_ENCRYPTION_KEY=""

# 微信公众号（可选，也可在页面「公众号配置」中填写）
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
