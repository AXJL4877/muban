generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id                String   @id
  name              String
  recordType        String   @default("template")
  savedAt           BigInt
  canvasSize        Json
  json              Json
  thumbnail         String?  @db.Text
  elements          Json
  elementCount      Int
  jsonPromptConfig  Json?
  imagePromptConfig Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([recordType, savedAt(sort: Desc)])
}

model AppState {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model CustomFont {
  filename  String   @id
  family    String
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
}
