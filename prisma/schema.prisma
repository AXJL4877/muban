generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String   @id
  name        String
  savedAt     BigInt
  canvasSize  Json
  json        Json
  thumbnail   String?
  elements    Json
  elementCount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
